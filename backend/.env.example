# Application
APP_NAME=BrightWaves Accounting
APP_VERSION=1.0.0
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://accounting:accounting123@localhost:5432/accounting_db

# Storage
STORAGE_BACKEND=local  # Options: local, s3
LOCAL_STORAGE_PATH=./uploads
S3_BUCKET_NAME=
S3_REGION=eu-west-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-domain.com

# File Upload
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,xml
